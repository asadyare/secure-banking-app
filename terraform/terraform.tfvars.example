# Copy to terraform.tfvars (gitignored) and edit for your AWS account.
# Do not commit real ARNs or secrets.

aws_region   = "us-east-1"
project_name = "baawisan-bank"
environment  = "staging"

# Optional: globally unique bucket name. Leave null to auto-generate from project_name + environment + suffix.
# bucket_name = "my-company-bank-staging-site"

# Custom domain (optional): set all three together. ACM certificate MUST be in us-east-1 for CloudFront.
# domain_name          = "app.example.com"
# hosted_zone_id       = "Z0XXXXXXXXXXXX"
# acm_certificate_arn  = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

enable_waf = false

# hsts_include_subdomains = true
# hsts_preload            = true

tags = {
  Owner = "platform"
}
